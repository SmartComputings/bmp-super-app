<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main App Theme using MaterialComponents -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6366F1</item>
        <item name="colorPrimaryDark">#4F46E5</item>
        <item name="colorAccent">#6366F1</item>
    </style>
    
    <style name="LaunchTheme" parent="AppTheme">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    
    <!-- Stripe Themes -->
    <style name="StripeAddPaymentMethodActivityTheme" parent="AppTheme" />
    <style name="StripePaymentMethodsActivityTheme" parent="AppTheme" />
</resources>